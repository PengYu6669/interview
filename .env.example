DATABASE_URL=postgresql+psycopg://interview:interview_dev@localhost:5432/interview_copilot
REDIS_URL=redis://localhost:6379/0
WEB_ORIGIN=http://localhost:3000
INTERVIEW_API_URL=http://localhost:8000
AUTH_SESSION_DAYS=7
AUTH_LOGIN_MAX_FAILURES=8
AUTH_LOGIN_WINDOW_SECONDS=900

# AI 服务。接入前必须根据当前官方文档核验模型 ID 和 endpoint。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=
DOUBAO_EMBEDDING_API_KEY=
DOUBAO_EMBEDDING_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal
DOUBAO_EMBEDDING_MODEL=

# 百度 OCR。优先使用 AK/SK 换取短期 token，禁止提交 access token。
BAIDU_OCR_ACCESS_TOKEN=
BAIDU_OCR_BEARER_TOKEN=
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# 科大讯飞 WebAPI 凭据，只能保存在服务端。
IFLYTEK_TTS_APP_ID=
IFLYTEK_TTS_API_KEY=
IFLYTEK_TTS_API_SECRET=
IFLYTEK_TTS_ENDPOINT=wss://tts-api.xfyun.cn/v2/tts
IFLYTEK_TTS_VOICE=xiaoyan
IFLYTEK_IAT_ENDPOINT=wss://iat-api.xfyun.cn/v2/iat
SPEECH_TICKET_SECRET=
NEXT_PUBLIC_INTERVIEW_WS_URL=ws://localhost:8000

# Coding Board 本地沙箱。生产 API 容器不得挂载 Docker Socket；上线前改用独立执行服务。
CODING_SANDBOX_ENABLED=true
CODING_SANDBOX_IMAGE=python:3.12.11-alpine3.22@sha256:efcdfa6a6b2fd2afb9c7dfa9a5b288a6f68338b5cfdebe6b637d986067d85757
CODING_SANDBOX_TIMEOUT_SECONDS=3
CODING_SANDBOX_MEMORY_MB=128
CODING_SANDBOX_CPU_COUNT=0.5
CODING_SANDBOX_PIDS_LIMIT=64
CODING_SANDBOX_OUTPUT_LIMIT_BYTES=65536
CODING_SANDBOX_MAX_CONCURRENCY=2

# 生产 Compose 使用。生产环境必须替换为高强度随机值和公开 HTTPS/WSS 地址。
POSTGRES_DB=interview_copilot
POSTGRES_USER=interview
POSTGRES_PASSWORD=
REDIS_PASSWORD=
WEB_PORT=3000
